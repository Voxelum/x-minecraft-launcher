{
    "exclude":  [
                    "node_modules",
                    "../xmcl",
                    "../xmcl-runtime-api"
                ],
    "include":  [
                    "src/**/*",
                    "src/**/*.vue",
                    "auto-imports.d.ts"
                ],
    "vueCompilerOptions":  {
                               "target":  2.7,
                               "experimentalSuppressUnknownJsxPropertyErrors":  false
                           },
    "compilerOptions":  {
                            "experimentalDecorators":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "moduleResolution":  "node",
                            "noImplicitAny":  false,
                            "module":  "ESNext",
                            "paths":  {
                                          "@/*":  [
                                                      "./src/*"
                                                  ],
                                          "~main/*":  [
                                                          "./src/windows/main/*"
                                                      ]
                                      },
                            "downlevelIteration":  true,
                            "types":  [
                                          "vite/client",
                                          "@xmcl/runtime-api/client",
                                          "@xmcl/runtime-api/monitorClient"
                                      ],
                            "baseUrl":  ".",
                            "strict":  true,
                            "target":  "ESNext",
                            "resolveJsonModule":  true,
                            "esModuleInterop":  true,
                            "jsx":  "preserve",
                            "skipLibCheck":  true
                        }
}
