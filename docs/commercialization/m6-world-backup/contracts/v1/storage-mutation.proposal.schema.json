{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:xmcl:m6:proposal:storage-mutation:v1",
  "title": "M6StorageMutationProposalV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "mutationId", "accountId", "operation", "occurredAt"],
  "properties": {
    "schemaVersion": { "const": "m6.storage-mutation.proposal.v1" },
    "mutationId": { "type": "string", "minLength": 1 },
    "accountId": { "type": "string", "minLength": 1 },
    "operation": {
      "enum": ["complete_upload", "delete_backup", "add_reference", "release_reference", "delete_object"]
    },
    "occurredAt": { "type": "string", "format": "date-time" },
    "backupId": { "type": "string", "minLength": 1 },
    "objectId": { "type": "string", "minLength": 1 },
    "expectedLastSettledAt": { "type": "string", "format": "date-time" }
  }
}