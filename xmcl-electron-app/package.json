{
  "name": "xmcl",
  "private": true,
  "main": "./index.js",
  "version": "0.54.4",
  "author": "ci010 <cijhn@hotmail.com>",
  "description": "X Minecraft Launcher - A modern Minecraft launcher",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voxelum/x-minecraft-launcher"
  },
  "msstoreCliAppId": "9MXJWHXTP4B9",
  "scripts": {
    "compile": "cross-env BUILD_TARGET=none tsx build.ts",
    "build": "cross-env NODE_ENV=production tsx build.ts",
    "build:all": "cross-env NODE_ENV=production cross-env BUILD_TARGET=all tsx build.ts",
    "postinstall": "tsx postinstall.ts",
    "postsign": "tsx postsign.ts",
    "fmt": "oxfmt -c ../.oxfmtrc.json .",
    "check": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project preload/tsconfig.json",
    "dev": "cross-env NODE_ENV=development tsx dev.ts",
    "lint": "oxlint -c ./node_modules/@xmcl/oxlint-config/oxlintrc.json .",
    "lint:fix": "bun run lint --fix"
  },
  "devDependencies": {
    "oxfmt": "^0.43.0",
    "app-builder-lib": "~26",
    "@electron/rebuild": "^4.0.3",
    "@types/electron-devtools-installer": "^4.0.0",
    "@types/fs-extra": "~11",
    "@types/graceful-fs": "^4.1.9",
    "@types/lodash.debounce": "^4.0.9",
    "@types/lodash.throttle": "^4.1.9",
    "@types/node": "^25.5.2",
    "@types/semver": "^7.7.1",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.0",
    "@xmcl/client": "workspace:*",
    "@xmcl/resource": "workspace:*",
    "@xmcl/core": "workspace:*",
    "@xmcl/utils": "workspace:*",
    "@xmcl/file-transfer": "workspace:*",
    "@xmcl/installer": "workspace:*",
    "@xmcl/runtime": "workspace:*",
    "@xmcl/runtime-api": "workspace:*",
    "@xmcl/oxlint-config": "workspace:*",
    "@xmcl/windows-utils": "^0.0.15",
    "builtin-modules": "^5.0.0",
    "chalk": "^5.6.2",
    "create-desktop-shortcuts": "^1.11.1",
    "cross-env": "^10.1.0",
    "dotenv": "17.4.1",
    "electron": "41.1.1",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^4.0.0",
    "electron-updater": "^6.8.3",
    "esbuild": "^0.28.0",
    "esbuild-plugin-yaml": "^0.0.1",
    "fast-xml-parser": "^5.5.10",
    "file-type": "^22.0.0",
    "filenamify": "^7.0.1",
    "fs-extra": "^11.3.4",
    "graceful-fs": "^4.2.11",
    "lodash.debounce": "^4.0.8",
    "node-datachannel": "0.32.2",
    "node-disk-info": "^1.3.0",
    "original-fs": "^1.2.0",
    "oxlint": "^1.58.0",
    "semver": "^7.7.4",
    "source-map-support": "^0.5.21",
    "node-abi": "4.28.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "undici": "8.0.2"
  },
  "trustedDependencies": [
    "electron",
    "node-datachannel",
    "@electron/rebuild"
  ]
}
