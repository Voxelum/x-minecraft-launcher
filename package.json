{
    "version": "0.61.0",
    "private": true,
    "license": "MIT",
    "packageManager": "pnpm@11.10.0",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "compile": "pnpm -r compile",
        "test": "vitest",
        "build:schema": "pnpm run --prefix=xmcl-runtime-api build:schema",
        "build": "pnpm run --prefix=xmcl-electron-app build",
        "build:all": "pnpm run --prefix=xmcl-electron-app build:all",
        "build:renderer": "pnpm --prefix=xmcl-keystone-ui build",
        "build:docs": "tsx scripts/docs.ts",
        "postsign": "pnpm run --prefix=xmcl-electron-app postsign",
        "check": "pnpm run --prefix=xmcl-runtime-api check && pnpm run --prefix=xmcl-runtime check && pnpm run --prefix=xmcl-electron-app check && pnpm run --prefix=xmcl-keystone-ui check",
        "dev:main": "pnpm run --prefix=xmcl-electron-app dev",
        "dev:renderer": "pnpm run --prefix=xmcl-keystone-ui dev",
        "lint": "oxlint -c ./.oxlintrc.json packages && pnpm run --prefix=xmcl-keystone-ui lint && pnpm run --prefix=xmcl-runtime lint && pnpm run --prefix=xmcl-runtime-api lint && pnpm run --prefix=xmcl-electron-app lint",
        "i18n": "pnpm run --prefix=xmcl-keystone-ui i18n",
        "lint:i18n": "pnpm run --prefix=xmcl-keystone-ui lint:i18n",
        "i18n:remove": "pnpm run --prefix=xmcl-keystone-ui i18n:remove",
        "i18n:rename": "pnpm run --prefix=xmcl-keystone-ui i18n:rename",
        "i18n:daemon": "pnpm run --prefix=xmcl-keystone-ui i18n:daemon",
        "lint:fix": "oxlint -c ./.oxlintrc.json packages --fix && pnpm run --prefix=xmcl-runtime-api lint:fix && pnpm run --prefix=xmcl-runtime lint:fix && pnpm run --prefix=xmcl-electron-app lint:fix && pnpm run --prefix=xmcl-keystone-ui lint:fix",
        "format": "oxfmt -c ./.oxfmtrc.json packages --write",
        "coverage": "vitest run --coverage",
        "test:e2e": "pnpm --prefix=e2e test",
        "test:e2e:smoke": "pnpm --prefix=e2e test:smoke",
        "test:e2e:ui": "pnpm --prefix=e2e test:ui",
        "test:e2e:scratch": "pnpm --prefix=e2e test:scratch",
        "e2e:install": "pnpm --dir=e2e install --ignore-workspace",
        "build:tutorial": "pnpm --prefix=e2e tutorial",
        "gen:testids": "tsx scripts/gen-testids.ts"
    },
    "devDependencies": {
        "@types/node": "^20.19.0",
        "@vitest/coverage-v8": "^4.1.0",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "tsx": "^4.21.0",
        "typedoc": "^0.28.15",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    },
    "pnpm": {
        "overrides": {
            "postcss": ">=8.5.10",
            "rolldown": "1.0.1",
            "ip": "^2.0.1",
            "form-data": "^4.0.4",
            "glob": "^10.5.0",
            "semver": "^7.5.4",
            "rollup": "^4.59.0",
            "lodash": "^4.18.1",
            "tar-fs": "^2.1.3",
            "@xmldom/xmldom": "^0.8.13",
            "minimatch": ">=3.1.3 <4.0.0 || >=5.1.7 <6.0.0 || >=9.0.6 <10.0.0 || >=10.2.1",
            "tar": "^7.5.3",
            "braces": "^3.0.3",
            "cross-spawn": ">=6.0.6 <7.0.0 || >=7.0.5",
            "undici": "^7.28.0",
            "tmp": "^0.2.7",
            "electron-updater": "^6.8.9",
            "picomatch": ">=2.3.2 <3.0.0 || >=3.0.2 <4.0.0 || >=4.0.4",
            "defu": "^6.1.5",
            "jws": ">=3.2.3 <4.0.0 || >=4.0.1",
            "ejs": "^3.1.10",
            "@nevware21/ts-utils": "^0.14.0",
            "brace-expansion": ">=1.1.13 <2.0.0 || >=2.0.3 <3.0.0 || >=3.0.2 <4.0.0 || >=5.0.6",
            "micromatch": "^4.0.8",
            "uuid": "^14.0.1",
            "ajv": ">=6.14.0 <7.0.0 || >=8.18.0",
            "js-yaml": "^4.2.0",
            "markdown-it": "^14.2.0",
            "@opentelemetry/core": "^2.8.0",
            "smol-toml": "^1.7.0",
            "esbuild": "^0.28.1",
            "@tootallnate/once": ">=2.0.1 <3.0.0 || >=3.0.1"
        }
    }
}