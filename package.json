{
  "version": "0.54.4",
  "private": true,
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.11"
  },
  "workspaces": [
    "xmcl/packages/**",
    "xmcl-electron-app",
    "xmcl-runtime-api",
    "xmcl-runtime",
    "xmcl-keystone-ui",
    ".github/actions/*",
    "packages/**"
  ],
  "scripts": {
    "postinstall": "bun setup.ts",
    "compile": "bun run --filter='*' compile",
    "test": "bunx vitest",
    "build:schema": "bun run --cwd=xmcl-runtime-api build:schema",
    "build": "bun run --cwd=xmcl-electron-app build",
    "build:all": "bun run --cwd=xmcl-electron-app build:all",
    "build:renderer": "bun run --cwd=xmcl-keystone-ui build",
    "postsign": "bun run --cwd=xmcl-electron-app postsign",
    "check": "bun run --filter='xmcl-runtime-api|xmcl-runtime|xmcl-electron-app|xmcl-keystone-ui' check",
    "dev:main": "bun run --cwd=xmcl-electron-app dev",
    "dev:renderer": "bun run --cwd=xmcl-keystone-ui dev",
    "dev": "bun dev.ts",
    "lint": "bun run --filter='xmcl-keystone-ui|xmcl-runtime|xmcl-runtime-api|xmcl-electron-app' lint",
    "lint:fix": "bun run --filter='xmcl-runtime-api|xmcl-runtime|xmcl-electron-app|xmcl-keystone-ui' lint:fix"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "trustedDependencies": [
    "electron",
    "node-datachannel",
    "@electron/rebuild"
  ]
}
