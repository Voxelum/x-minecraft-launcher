{
  "name": "@xmcl/e2e",
  "private": true,
  "version": "0.0.0",
  "description": "End-to-end tests for X Minecraft Launcher. Each spec is also a tutorial source: shots + captions are emitted into a manifest that scripts/build-tutorial.ts compiles into docs/tutorial/*.md.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test specs/00-smoke-boot.spec.ts",
    "test:scratch": "playwright test specs/scratch",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:update": "playwright test --update-snapshots",
    "tutorial": "tsx ../scripts/build-tutorial.ts",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
